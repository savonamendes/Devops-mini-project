# ============================================================
#  ODR India – Docker Environment Template
#  Copy this file to .env and fill in your real values.
#  Run: cp .env.example .env
# ============================================================

# ─── Database (AWS RDS PostgreSQL) ───────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
DATABASE_URL=postgresql://postgres:yourpassword@your-rds-endpoint.rds.amazonaws.com:5432/odrindia?sslmode=require

# ─── Auth & Sessions ─────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-at-least-64-chars
SESSION_SECRET=another-long-random-string-for-sessions
SESSION_DURATION_HOURS=24

# ─── Together AI (chatbot feature) ───────────────────────────
TOGETHER_API_KEY=your-together-ai-api-key

# ─── SendGrid (transactional email) ──────────────────────────
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@odrlab.com

# ─── Frontend public vars (baked into the Next.js build) ─────
# URL users' browsers use to reach the API.
# If running locally with docker compose:  http://localhost:3000/api
# If behind nginx/domain:                  https://yourdomain.com/api
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api

# Google OAuth client id (public, safe to expose)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Jitsi video conferencing
NEXT_PUBLIC_JITSI_SERVER=meet.jit.si
NEXT_PUBLIC_JITSI_ROOM_PREFIX=odrindia-
